# Copy this file to .env.local and fill in real values. Never commit .env.local.
# This project intentionally shares its database with hardvanta — DATABASE_URL
# and DIRECT_URL must point at the same Supabase Postgres instance.

# --- Shared Supabase Postgres (same database as hardvanta) ---
DATABASE_URL="postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@[host]:5432/postgres"

# --- NextAuth (own secret/URL — independent from hardvanta's session cookies) ---
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# --- Google OAuth ---
# Can reuse hardvanta's OAuth client, but this app's callback URL must be added
# to its "Authorized redirect URIs" in Google Cloud Console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Resend (login OTP + password reset emails) ---
# Until both are set, codes are logged to the server console instead of emailed.
RESEND_API_KEY=""
EMAIL_FROM="hardvanta Admin <noreply@yourdomain>"
